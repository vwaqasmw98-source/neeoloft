# ─── Core ──────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/neeoloft
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
APP_URL=http://localhost:3000
# Used by sitemap.ts, robots.ts, canonical URLs, OpenGraph — set this in prod!
NEXT_PUBLIC_SITE_URL=https://neeoloft.com

# ─── AI / LLM (FREE — Groq) ───────────────────────────────────────
# Get free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.1-70b-versatile
# Alternative models: mixtral-8x7b-32768, llama-3.1-8b-instant

# ─── Stripe (optional but recommended) ────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx
STRIPE_PRICE_STARTER_MONTHLY=price_xxx
STRIPE_PRICE_STARTER_YEARLY=price_xxx
STRIPE_PRICE_GROWTH_MONTHLY=price_xxx
STRIPE_PRICE_GROWTH_YEARLY=price_xxx
STRIPE_PRICE_AGENCY_MONTHLY=price_xxx
STRIPE_PRICE_AGENCY_YEARLY=price_xxx

# ─── Email (optional) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=hello@neeoloft.com
SMTP_PASS=app-specific-password
ADMIN_EMAIL=admin@neeoloft.com

# ─── WhatsApp / Twilio (optional) ─────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
ADMIN_WHATSAPP_NUMBER=whatsapp:+91xxxxxxxxxx

# ─── Notifications (optional) ─────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# ─── Cal.com (optional, legacy) ─────────────────────────────────
# No longer used by /book (we run our own booking form now).
# Kept here in case you want to wire it back via custom code.
# NEXT_PUBLIC_CALCOM_EMBED_LINK=neeoloft/strategy-call
# NEXT_PUBLIC_CALCOM_LINK=https://cal.com/neeoloft/strategy-call

# ─── Voice agents (optional) ──────────────────────────────────────
# For phone-call based voice agents (separate from in-widget Web Speech)
VAPI_API_KEY=xxxxxxxxxxxxxxxx
VAPI_WEBHOOK_SECRET=replace-with-strong-secret

# ─── Voice AI in chat widget (optional) ───────────────────────────
# The widget uses the browser Web Speech API by default — free, no key needed.
# To upgrade STT/TTS quality, plug in:
OPENAI_API_KEY=sk-xxxxxxxxxxxxxx # Whisper (STT) + TTS
ELEVENLABS_API_KEY=xxxxxxxxxxxx  # Premium TTS voices

# ─── Legacy admin basic auth (for /admin/leads-export) ───────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now
